        "format": "<template>\n  <div style=\"display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;padding:8px;box-sizing:border-box;\">\n    <div style=\"display:flex;align-items:baseline;gap:12px;margin-bottom:2px;\">\n      <div style=\"font-size:13px;color:#717171;font-family:Arial;\">Battery</div>\n      <div style=\"font-size:13px;color:#9e9e9e;font-family:Arial;\">{{ formatVoltage(msg.payload) }}</div>\n    </div>\n    <div :style=\"{fontSize:'32px',fontWeight:'bold',fontFamily:'Arial',color:getColor(msg.payload),marginBottom:'8px'}\">{{ formatCurrent(msg.payload) }}</div>\n    <div style=\"position:relative;width:90%;height:14px;background:#e0e0e0;border-radius:7px;overflow:hidden;\">\n      <div style=\"position:absolute;left:50%;top:0;width:2px;height:100%;background:#9e9e9e;transform:translateX(-50%);z-index:1;\"></div>\n      <div :style=\"getBarStyle(msg.payload)\"></div>\n    </div>\n    <div style=\"display:flex;justify-content:space-between;width:90%;margin-top:3px;font-size:10px;color:#9e9e9e;font-family:Arial;\">\n      <span>-200A</span><span>0</span><span>+200A</span>\n    </div>\n  </div>\n</template>\n<script>\nexport default {\n  methods: {\n    getCurrent(v) {\n      if (v == null) return 0\n      return typeof v === 'object' ? Number(v.current || 0) : Number(v)\n    },\n    formatCurrent(v) {\n      const a = this.getCurrent(v)\n      return (a >= 0 ? '+' : '') + a.toFixed(0) + ' A'\n    },\n    formatVoltage(v) {\n      if (v == null || typeof v !== 'object' || v.voltage == null) return ''\n      return Number(v.voltage).toFixed(1) + 'V'\n    },\n    getColor(v) {\n      const a = this.getCurrent(v)\n      if (a < -50) return '#1565C0'\n      if (a < -10) return '#42A5F5'\n      if (a <  10) return '#78909C'\n      return '#4CAF50'\n    },\n    getBarStyle(v) {\n      const max = 200\n      const a = this.getCurrent(v)\n      const pct = Math.min(Math.abs(a) / max, 1) * 50\n      const c = this.getColor(v)\n      return a >= 0\n        ? { position:'absolute', left:'50%', width:pct+'%', height:'100%', background:c, borderRadius:'0 7px 7px 0', transition:'width 0.4s ease' }\n        : { position:'absolute', right:'50%', width:pct+'%', height:'100%', background:c, borderRadius:'7px 0 0 7px', transition:'width 0.4s ease' }\n    }\n  }\n}\n</script>",
