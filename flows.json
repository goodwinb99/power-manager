    {
        "id": "aa00000000000050",
        "type": "function",
        "z": "aa00000000000001",
        "name": "Dashboard Formatter",
        "func": "const d = msg.payload;\nif (!d || typeof d !== \"object\") return null;\n\n// out1: SOC gauge\nconst socMsg = { payload: d.soc };\n\n// out2: Shore status text (HTML with color)\nlet statusText = \"\";\nlet color = \"#4CAF50\";\n\nif (d.shoreMode === \"on\") {\n    statusText = \"Shore connected (manual)\";\n    color = \"#2196F3\";\n} else if (d.shoreMode === \"off\") {\n    statusText = \"Shore disconnected (manual)\";\n    color = \"#9E9E9E\";\n} else if (d.state === \"SHORE_ON\" && d.connectReason === \"soc\") {\n    statusText = \"Shore connected (SOC)\";\n    color = \"#FF9800\";\n} else if (d.state === \"SHORE_ON\" && d.connectReason === \"voltage\") {\n    statusText = \"Shore connected (voltage)\";\n    color = \"#FF9800\";\n} else if (d.state === \"SHORE_ON\") {\n    statusText = \"Shore connected\";\n    color = \"#FF9800\";\n} else if (d.state === \"SHORE_OFF\") {\n    statusText = \"Shore disconnected\";\n    color = \"#4CAF50\";\n}\nconst statusHtml = statusText\n    ? '<span style=\"color:' + color + ';font-size:14px;\">' + statusText + '</span>'\n    : \"\";\n\nreturn [\n    socMsg,\n    { payload: statusHtml },\n    { payload: d.acOutL1 },\n    { payload: d.acOutL2 },\n    { payload: d.shoreInL1 || 0 },\n    { payload: d.shoreInL2 || 0 },\n    { payload: d.mpptPower },\n    { payload: { current: d.batteryCurrent, voltage: d.voltage } }\n];",
