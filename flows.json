    {
        "id": "aa00000000000030",
        "type": "function",
        "z": "aa00000000000001",
        "name": "State Machine",
        "func": "// Store sensor data by topic (skip timer messages)\nif (msg.topic && msg.topic !== \"timer\" && msg.payload !== undefined) {\n    flow.set(\"sensor_\" + msg.topic, msg.payload);\n}\n\n// Read config\nconst soc = flow.get(\"sensor_soc\") || 0;\nconst enabled = flow.get(\"enabled\") || false;\nconst thresholdLow = flow.get(\"threshold_low\") || 40;\nconst thresholdHigh = flow.get(\"threshold_high\") || 60;\nconst voltage = flow.get(\"sensor_batt_voltage\") || 0;\nconst voltageThresholdLow = flow.get(\"voltage_threshold_low\") || 48.0;\nlet state = flow.get(\"state\") || \"SHORE_OFF\";\nconst lastChange = flow.get(\"last_state_change\") || 0;\nconst now = Date.now();\n\n// Collect dashboard data (always sent)\nconst acOutL1 = flow.get(\"sensor_ac_out_l1\") || 0;\nconst acOutL2 = flow.get(\"sensor_ac_out_l2\") || 0;\nconst mpptPower = flow.get(\"sensor_mppt_power\") || 0;\nconst batteryCurrent = flow.get(\"sensor_batt_current\") || 0;\nconst shoreInL1 = flow.get(\"sensor_shore_in_l1\") || 0;\nconst shoreInL2 = flow.get(\"sensor_shore_in_l2\") || 0;\nconst battTempC = flow.get(\"sensor_batt_temp\");\nconst battTempF = battTempC != null ? Math.round(battTempC * 9/5 + 32) : null;\n\nconst dashboard = {\n    state: enabled ? state : \"MANUAL\",\n    soc,\n    enabled,\n    thresholdLow,\n    thresholdHigh,\n    acOutL1,\n    acOutL2,\n    acTotal: acOutL1 + acOutL2,\n    mpptPower,\n    batteryCurrent,\n    shorePower: shoreInL1 + shoreInL2,\n    shoreInL1,\n    shoreInL2,\n    battTempF,\n    voltage: flow.get(\"sensor_batt_voltage\") || 0,\n    voltageThresholdLow,\n    connectReason: flow.get('connect_reason') || null,\n    shoreMode: flow.get('shore_mode') || 'off'\n};\n\n// Only evaluate on timer tick\nif (msg.topic !== \"timer\") {\n    return null;\n}\n\n// Automation disabled \u2014 safe defaults, don't control IgnoreAcIn2\nif (!enabled) {\n    flow.set(\"state\", \"SHORE_OFF\");\n    // out1=null (no IgnoreAcIn2 write), out2=null (relay is manual-only), out3=dashboard\n    return [null, null, { payload: dashboard }];\n}\n\n// Hysteresis with 30s minimum transition interval\nif ((now - lastChange) >= 30000) {\n    if (state === \"SHORE_OFF\" && ((soc > 0 && soc <= thresholdLow) || (voltage > 0 && voltage <= voltageThresholdLow))) {\n        state = \"SHORE_ON\";\n        flow.set(\"last_state_change\", now);\n        flow.set(\"connect_reason\", (soc > 0 && soc <= thresholdLow) ? \"soc\" : \"voltage\");\n        node.warn(\"Transition: SHORE_OFF -> SHORE_ON (SOC=\" + soc + \"%, V=\" + voltage + \"V)\");\n    } else if (state === \"SHORE_ON\" && soc >= thresholdHigh && (voltage === 0 || voltage > voltageThresholdLow)) {\n        state = \"SHORE_OFF\";\n        flow.set(\"last_state_change\", now);\n        node.warn(\"Transition: SHORE_ON -> SHORE_OFF (SOC=\" + soc + \"%, V=\" + voltage + \"V)\");\n    }\n}\nflow.set(\"state\", state);\n\n// Update dashboard state after possible transition\ndashboard.state = state;\n\n// Output control values\nconst ignoreAcIn2 = (state === \"SHORE_ON\") ? 0 : 1;\nreturn [\n    { payload: ignoreAcIn2 },   // out1: IgnoreAcIn2\n    null,                        // out2: relay controlled manually, not by automation\n    { payload: dashboard }       // out3: Dashboard\n];",
        "outputs": 3,
        "timeout": "",
        "noerr": 0,
        "initialize": "// Set defaults for missing keys only (preserve state across deploys)\n// Migrate old state names\nif (flow.get('state') === 'SOLAR_ONLY') flow.set('state', 'SHORE_OFF');\nif (flow.get('state') === 'GRID_ASSIST') flow.set('state', 'SHORE_ON');\nif (flow.get('state') === undefined) flow.set('state', 'SHORE_OFF');\nif (flow.get('enabled') === undefined) flow.set('enabled', false);\nif (flow.get('shore_mode') === undefined) flow.set('shore_mode', 'off');\nif (flow.get('threshold_low') === undefined) flow.set('threshold_low', 40);\nif (flow.get('threshold_high') === undefined) flow.set('threshold_high', 60);\nif (flow.get('voltage_threshold_low') === undefined) flow.set('voltage_threshold_low', 48.0);\nif (flow.get('last_state_change') === undefined) flow.set('last_state_change', 0);\nif (flow.get('manual_relay') === undefined) flow.set('manual_relay', false);",
        "finalize": "",
        "libs": [],
